
/*
 * Model Context Protocol (MCP) server for a Magic backend, speaking JSON-RPC 2.0 over HTTP at the
 * single endpoint POST /magic/modules/mcp/mcp. Its purpose is to expose the cloudlet's own dynamic
 * Hyperlambda endpoints to MCP clients (Claude Desktop, Cursor, the Claude API, ...) as callable
 * "tools", reusing the platform's existing endpoint discovery and invocation so that a tool reaches
 * the exact same endpoint, enforcing the exact same per-endpoint authorisation, as a normal HTTP
 * request would. Responses are plain JSON, a spec-compliant subset of the Streamable HTTP transport;
 * no Server-Sent Events are used.
 *
 * The whole JSON-RPC envelope arrives untyped, so the endpoint accepts any arguments. A message that
 * carries no [id] is a JSON-RPC notification: it is acknowledged with HTTP status 202 and an empty
 * body, and nothing else happens. A message that carries an [id] is a request, and is answered with a
 * JSON-RPC reply object holding "jsonrpc" set to "2.0" and the same [id] echoed back, after which the
 * [method] is dispatched:
 *
 *   - "initialize" returns the handshake result: a protocolVersion (the client's requested
 *     params.protocolVersion when present, otherwise 2024-11-05), a capabilities object advertising a
 *     non-list-changing "tools" capability, and a serverInfo naming the server "magic-mcp".
 *
 *   - "ping" returns an empty result.
 *
 *   - "tools/list" builds the catalogue by executing /modules/mcp/tools.hl (forwarding the optional
 *     [path] query argument that scopes a server instance to a single module), then turns every
 *     catalogued endpoint into an MCP tool descriptor carrying its name, its description and an
 *     inputSchema JSON-schema object of "type":"object". For every declared argument a property is
 *     added under inputSchema/properties, named after the argument, whose JSON-schema "type" is
 *     derived from the Hyperlambda type: short, ushort, int, uint, long, ulong, byte and sbyte become
 *     "integer"; decimal, double, single and float become "number"; bool becomes "boolean"; date and
 *     guid become "string" but additionally carry a "format" of "date-time" respectively "uuid"; the
 *     structured * type becomes "object"; and anything else (string, char, time, ...) becomes "string". An argument whose catalogue entry
 *     carries a description - resolved from the comment directly above the argument in the file's
 *     [.arguments] node - additionally gets that text as the property's "description". The
 *     descriptors accumulate as an array under result/tools.
 *
 *   - "tools/call" resolves params.name against the same /modules/mcp/tools.hl catalogue, so a client
 *     can only ever invoke a tool that was also listed, and only within the optional [path] scope. On
 *     a match the resolved endpoint file is invoked with params.arguments inside a [try], so that a
 *     throwing endpoint is reported in-band as an MCP tool error instead of leaking as a raw HTTP
 *     failure the client discards: on success the endpoint's result is serialised to JSON and returned
 *     as a single text content block; on failure the exception is logged server-side and returned as a
 *     text content block with "isError" set to true, relaying the real message only when the endpoint
 *     marked the exception public and a generic "Tool execution failed" otherwise. A name that
 *     resolves to nothing yields the JSON-RPC error -32602 with message "Unknown tool: <name>".
 *
 *   - any other method yields the JSON-RPC error -32601 with message "Method not found".
 */
.arguments:*

/*
 * Requiring an authenticated Magic user. An unauthenticated request gets a 401 whose WWW-Authenticate
 * header points OAuth clients at this cloudlet's protected-resource metadata, so they can discover and
 * run the OAuth flow automatically (see the "oauth" module). Remove this block to make the server anonymous.
 */
auth.ticket.get
if
   null:x:@auth.ticket.get
   .lambda
      .meta-url
      set-value:x:@.meta-url
         strings.concat
            .:"https://"
            request.host
            .:/.well-known/oauth-protected-resource
      .challenge
      set-value:x:@.challenge
         strings.concat
            .:"Bearer resource_metadata="
            .:'"'
            get-value:x:@.meta-url
            .:'"'
      response.headers.set
         WWW-Authenticate:x:@.challenge
      response.status.set:401
      return
         error:unauthorized
         error_description:Authentication required

if
   not-exists:x:@.arguments/*/id
   .lambda
      response.status.set:202
else

   .envelope
      jsonrpc:2.0
      id
   set-value:x:@.envelope/*/id
      get-value:x:@.arguments/*/id

   switch:x:@.arguments/*/method

      case:initialize

         .version:2024-11-05
         if
            exists:x:@.arguments/*/params/*/protocolVersion
            .lambda
               set-value:x:@.version
                  get-value:x:@.arguments/*/params/*/protocolVersion
         add:x:@.envelope
            .
               result
                  protocolVersion
                  capabilities
                     tools
                        listChanged:bool:false
                  serverInfo
                     name:magic-mcp
                     version:1.0.0
                  instructions
         set-value:x:@.envelope/*/result/*/protocolVersion
            get-value:x:@.version

         // Delivering the operating instructions to the client, loaded dynamically so edits take effect
         // without a restart. The instructions tell the client to call [whoami] to resolve session context.
         set-value:x:@.envelope/*/result/*/instructions
            io.file.load:/modules/mcp/system-instruction.md
         return-nodes:x:@.envelope/*

      case:ping

         add:x:@.envelope
            .
               result
         return-nodes:x:@.envelope/*

      case:tools/list

         add:x:@.envelope
            .
               result
                  tools
         execute-file:/modules/mcp/tools.hl
            path:x:@.arguments/*/path
         for-each:x:@execute-file/*

            .tool
            add:x:@.tool
               .
                  name
                  description
                  inputSchema
                     type:object
            set-value:x:@.tool/*/name
               get-value:x:@.dp/#/*/name
            set-value:x:@.tool/*/description
               get-first-value
                  get-value:x:@.dp/#/*/description
                  .:No description available

            if
               exists:x:@.dp/#/*/input/*
               .lambda
                  add:x:@.tool/*/inputSchema
                     .
                        properties
                  for-each:x:@.dp/#/*/input/*

                     .jtype
                     .jformat
                     switch:x:@.dp/#/*/type
                        case:short
                        case:ushort
                        case:int
                        case:uint
                        case:long
                        case:ulong
                        case:byte
                        case:sbyte
                           set-value:x:@.jtype
                              .:integer
                        case:decimal
                        case:double
                        case:single
                        case:float
                           set-value:x:@.jtype
                              .:number
                        case:bool
                           set-value:x:@.jtype
                              .:boolean
                        case:date
                           set-value:x:@.jtype
                              .:string
                           set-value:x:@.jformat
                              .:date-time
                        case:guid
                           set-value:x:@.jtype
                              .:string
                           set-value:x:@.jformat
                              .:uuid
                        case:*
                           set-value:x:@.jtype
                              .:object
                        default
                           set-value:x:@.jtype
                              .:string

                     unwrap:x:+/+/*/**
                     set-name:x:+/*/*
                        get-value:x:@.dp/#/*/name
                     add:x:@.tool/*/inputSchema/*/properties
                        .
                           name
                              type:x:@.jtype

                     if
                        not-null:x:@.jformat
                        .lambda
                           unwrap:x:+/*/*
                           add:x:@.tool/*/inputSchema/*/properties/0/-
                              .
                                 format:x:@.jformat

                     if
                        not-null:x:@.dp/#/*/description
                        .lambda
                           unwrap:x:+/*/*
                           add:x:@.tool/*/inputSchema/*/properties/0/-
                              .
                                 description:x:@.dp/#/*/description

            add:x:@.envelope/*/result/*/tools
               .
                  .
            add:x:@.envelope/*/result/*/tools/0/-
               get-nodes:x:@.tool/*
         return-nodes:x:@.envelope/*

      case:tools/call

         .file
         execute-file:/modules/mcp/tools.hl
            path:x:@.arguments/*/path
         for-each:x:@execute-file/*
            if
               eq
                  get-value:x:@.dp/#/*/name
                  get-value:x:@.arguments/*/params/*/name
               .lambda
                  set-value:x:@.file
                     get-value:x:@.dp/#/*/file

         if
            not-null:x:@.file
            .lambda

               .text
               try

                  add:x:+
                     get-nodes:x:@.arguments/*/params/*/arguments/*
                  execute-file:x:@.file
                  if
                     exists:x:@execute-file/*
                     .lambda
                        set-value:x:@.text
                           lambda2json:x:@execute-file/*
                  else
                     set-value:x:@.text
                        get-value:x:@execute-file
                  add:x:@.envelope
                     .
                        result
                           content
                              .
                                 type:text
                                 text

               .catch

                  log.error:x:@.arguments/*/message
                     type:x:@.arguments/*/type
                  set-value:x:@.text
                     .:Tool execution failed
                  if
                     eq
                        get-value:x:@.arguments/*/public
                        .:bool:true
                     .lambda
                        set-value:x:@.text
                           get-value:x:@.arguments/*/message
                  add:x:@.envelope
                     .
                        result
                           content
                              .
                                 type:text
                                 text
                           isError:bool:true

               set-value:x:@.envelope/*/result/*/content/*/*/text
                  get-value:x:@.text
               return-nodes:x:@.envelope/*

         else

            .msg
            set-value:x:@.msg
               strings.concat
                  .:"Unknown tool: "
                  get-value:x:@.arguments/*/params/*/name
            add:x:@.envelope
               .
                  error
                     code:int:-32602
                     message
            set-value:x:@.envelope/*/error/*/message
               get-value:x:@.msg
            return-nodes:x:@.envelope/*

      default

         add:x:@.envelope
            .
               error
                  code:int:-32601
                  message:Method not found
         return-nodes:x:@.envelope/*
